---
import { AssistantWidget } from '~/components/assistant-widget'
import { getTranslationForLocale } from '~/i18n/ui'
import { CyoDesignLogo } from '~/components/logo'

interface Props {
  locale: string
}

const { locale } = Astro.props
const ui = getTranslationForLocale(locale ?? 'en')
---

<html lang="en">
  <head>
    <!-- Montserrat Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <style>
      html,
      body {
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
      }

      img,
      video,
      iframe {
        max-width: 100%;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
    </style>
  </head>

  <body class="bg-primary-dark text-gray-900 font-[Montserrat] overflow-x-hidden">

    {/* HEADER */}
    <header class="absolute top-6 left-0 w-full z-[100] flex items-center justify-between px-4 md:px-6">

      {/* Home Icon */}
      <a
        href="https://store.cyodesign.com/"
        class="text-white hover:opacity-70 transition"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5 md:w-6 md:h-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M3 10.5L12 3l9 7.5M4.5 9.75V21h15V9.75"
          />
        </svg>
      </a>

      {/* Logo */}
      <a
        href="https://store.cyodesign.com/"
        class="absolute left-1/2 -translate-x-1/2"
      >
        <CyoDesignLogo
          size={120}
          className="text-white md:size-[140px]"
        />
      </a>

    </header>

    {/* HERO BANNER */}
    <section class="relative w-full max-w-full overflow-hidden">

      <img
        src="https://cdn.shopify.com/s/files/1/0955/9031/8455/files/Collection_Moody_luxury_editorial_product_photography_202605011506.jpg?v=1777888578"
        alt="CYO Design Banner"
        class="block w-full max-w-full h-[320px] sm:h-[450px] md:h-[550px] lg:h-[700px] object-cover"
      />

      {/* Overlay */}
      <div class="absolute inset-0 bg-black/40"></div>

      {/* Content */}
      <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4 md:px-6">

        <h1 class="text-white text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-light tracking-wide mb-4 max-w-[90%] break-words">
          Create Your Own Jewelry
        </h1>

        <p class="text-white/90 text-sm sm:text-base md:text-lg lg:text-xl max-w-2xl mb-8">
          Discover Our Collections
        </p>

        <div class="flex flex-wrap justify-center gap-3 md:gap-4">

          <a
            href="https://store.cyodesign.com/"
            class="px-6 md:px-8 py-3 bg-white text-black uppercase tracking-[0.2em] text-[11px] md:text-xs hover:opacity-90 transition"
          >
            Home
          </a>

          <a
            href="https://store.cyodesign.com/collections"
            class="px-6 md:px-8 py-3 border border-white text-white uppercase tracking-[0.2em] text-[11px] md:text-xs hover:bg-white hover:text-black transition"
          >
            Collections
          </a>

        </div>

      </div>

    </section>
{/* AI Widget */} 
<div class="w-full max-w-[900px] h-auto md:h-[600px] flex justify-center items-center"> 

<AssistantWidget client:load locale={locale ?? 'en'} /> </div> 

{/* Back Button */} 
<a href="https://store.cyodesign.com/" class="text-white text-[14px] md:text-[15px] font-light underline underline-offset-4 tracking-wide hover:opacity-70 transition" > 
Back to Home 
</a>
</section> 
</body> 
</html>


