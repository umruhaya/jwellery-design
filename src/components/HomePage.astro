---
import { AssistantWidget } from '~/components/assistant-widget'
import { getTranslationForLocale } from '~/i18n/ui'
import { CyoDesignLogo } from '~/components/logo'

interface Props {
  locale: string
}

const { locale } = Astro.props
const ui = getTranslationForLocale(locale ?? 'en')
---

<html lang="en">
  <head>
    <!-- Montserrat Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-white text-gray-900 font-[Montserrat]">

    {/* HEADER */}
    <header class="absolute top-10 left-0 w-full z-50 flex items-center justify-between px-6">

      {/* LEFT: Home Icon */}
      <a 
        href="https://store.cyodesign.com/" 
        class="text-white hover:opacity-70 transition duration-300"
      >
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          class="w-6 h-6" 
          fill="none" 
          viewBox="0 0 24 24" 
          stroke="currentColor"
        >
          <path 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            stroke-width="1.5" 
            d="M3 10.5L12 3l9 7.5M4.5 9.75V21h15V9.75" 
          />
        </svg>
      </a>

      {/* CENTER: LOGO */}
      <a 
        href="https://store.cyodesign.com/" 
        class="absolute left-1/2 transform -translate-x-1/2"
      >
        <CyoDesignLogo 
          size={140} 
          className="text-white hover:opacity-80 transition duration-300" 
        />
      </a>

    </header>

    {/* AI SECTION */}
<section class="w-full min-h-screen flex flex-col items-center justify-center bg-primary-dark pt-[120px] pb-16 gap-[40px]">

      {/* AI Widget */}
      <div class="w-[95%] h-[600px] flex justify-center items-center mx-auto">
        <AssistantWidget client:load locale={locale ?? 'en'} />
      </div>

      {/* BOTTOM BUTTON */}
   <a 
  href="https://store.cyodesign.com/"
  class="text-white text-[15px] font-light underline underline-offset-4 tracking-wide hover:opacity-70 transition"
>
  Back to Home
</a>

    </section>

  </body>
</html>
